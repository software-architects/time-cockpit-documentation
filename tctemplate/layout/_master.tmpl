<!DOCTYPE html>
<!--[if IE]><![endif]-->
<html lang="en">
  {{>partials/head}}
  <body data-spy="scroll" data-target="#affix">
    <div id="wrapper">
      <header>
        {{^_disableNavbar}}
        {{>partials/navbar}}
        {{/_disableNavbar}}
        {{^_disableBreadcrumb}}
        {{>partials/breadcrumb}}
        {{/_disableBreadcrumb}}
      </header>
      {{#_enableSearch}}
      <div class="container body-content">
        {{>partials/searchResults}}
      </div>
      {{/_enableSearch}}
      <div role="main" class="container body-content hide-when-search">
      {{^_disableToc}}
        {{>partials/toc}}
        <div class="article row grid-right">
      {{/_disableToc}}
      {{#_disableToc}}
        <div class="article row grid">
        {{/_disableToc}}
          {{#_disableAffix}}
          <div class="col-md-12">
          {{/_disableAffix}}
          {{^_disableAffix}}
          <div class="col-md-10">
          {{/_disableAffix}}
            <article class="content wrap" id="_content" data-uid="{{uid}}">
                {{!body}}
            </article>
          </div>
          {{^_disableAffix}}
          {{>partials/affix}}
          {{/_disableAffix}}
        </div>
      </div>
      {{^_disableFooter}}
      {{>partials/footer}}
      {{/_disableFooter}}
    </div>
    {{>partials/scripts}}
    <script type="module">
      (async () => {
        const minZoom = 0.5;
        const maxZoom = 3;
        const zoomStep = 0.25;
        const mermaidBlocks = document.querySelectorAll("pre code.lang-mermaid, pre code.language-mermaid");
        if (!mermaidBlocks.length) {
          return;
        }

        const clampZoom = (zoom) => Math.min(maxZoom, Math.max(minZoom, zoom));

        const updateZoom = (figure, zoom) => {
          const normalizedZoom = clampZoom(zoom);
          const svg = figure.querySelector(".mermaid svg");
          const zoomLabel = figure.querySelector(".mermaid-zoom-level");

          figure.dataset.zoom = normalizedZoom.toFixed(2);

          if (svg) {
            svg.style.width = `${normalizedZoom * 100}%`;
            svg.style.maxWidth = "none";
            svg.style.height = "auto";
          }

          if (zoomLabel) {
            zoomLabel.textContent = `${Math.round(normalizedZoom * 100)}%`;
          }
        };

        const attachZoomControls = (figure) => {
          const toolbar = figure.querySelector(".mermaid-toolbar");
          if (!toolbar) {
            return;
          }

          updateZoom(figure, 1);

          toolbar.addEventListener("click", (event) => {
            const button = event.target.closest("[data-mermaid-zoom]");
            if (!button) {
              return;
            }

            const currentZoom = Number.parseFloat(figure.dataset.zoom || "1");
            const action = button.dataset.mermaidZoom;

            if (action === "in") {
              updateZoom(figure, currentZoom + zoomStep);
            } else if (action === "out") {
              updateZoom(figure, currentZoom - zoomStep);
            } else if (action === "reset") {
              updateZoom(figure, 1);
            }
          });
        };

        const attachPanControls = (figure) => {
          const viewport = figure.querySelector(".mermaid-viewport");
          if (!viewport) {
            return;
          }

          let activePointerId = null;
          let startX = 0;
          let startY = 0;
          let startScrollLeft = 0;
          let startScrollTop = 0;

          const endPan = () => {
            activePointerId = null;
            viewport.classList.remove("is-dragging");
          };

          viewport.addEventListener("pointerdown", (event) => {
            if (event.button !== 0) {
              return;
            }

            activePointerId = event.pointerId;
            startX = event.clientX;
            startY = event.clientY;
            startScrollLeft = viewport.scrollLeft;
            startScrollTop = viewport.scrollTop;

            viewport.classList.add("is-dragging");
            viewport.setPointerCapture(event.pointerId);
            event.preventDefault();
          });

          viewport.addEventListener("pointermove", (event) => {
            if (activePointerId !== event.pointerId) {
              return;
            }

            const deltaX = event.clientX - startX;
            const deltaY = event.clientY - startY;

            viewport.scrollLeft = startScrollLeft - deltaX;
            viewport.scrollTop = startScrollTop - deltaY;
          });

          viewport.addEventListener("pointerup", (event) => {
            if (activePointerId === event.pointerId) {
              viewport.releasePointerCapture(event.pointerId);
              endPan();
            }
          });

          viewport.addEventListener("pointercancel", endPan);
          viewport.addEventListener("dragstart", (event) => event.preventDefault());
          viewport.addEventListener("lostpointercapture", endPan);
        };

        try {
          const { default: mermaid } = await import("https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs");

          mermaid.initialize({
            startOnLoad: false,
            securityLevel: "loose",
            theme: "default",
            er: {
              useMaxWidth: true,
            },
          });

          mermaidBlocks.forEach((codeBlock, index) => {
            const figure = document.createElement("figure");
            figure.className = "mermaid-figure";
            figure.dataset.zoom = "1";

            const toolbar = document.createElement("div");
            toolbar.className = "mermaid-toolbar";
            toolbar.innerHTML = `
              <button type="button" class="mermaid-zoom-button" data-mermaid-zoom="out" aria-label="Zoom out">-</button>
              <span class="mermaid-zoom-level" aria-live="polite">100%</span>
              <button type="button" class="mermaid-zoom-button" data-mermaid-zoom="in" aria-label="Zoom in">+</button>
              <button type="button" class="mermaid-zoom-button" data-mermaid-zoom="reset" aria-label="Reset zoom">Reset</button>
            `;

            const viewport = document.createElement("div");
            viewport.className = "mermaid-viewport";

            const container = document.createElement("div");
            container.className = "mermaid";
            container.id = `mermaid-diagram-${index}`;
            container.textContent = codeBlock.textContent;

            viewport.appendChild(container);
            figure.append(toolbar, viewport);
            codeBlock.parentElement.replaceWith(figure);
          });

          await mermaid.run({
            nodes: Array.from(document.querySelectorAll(".mermaid")),
          });

          document.querySelectorAll(".mermaid-figure").forEach((figure) => {
            attachZoomControls(figure);
            attachPanControls(figure);
          });
        } catch (error) {
          console.error("Failed to render Mermaid diagrams.", error);
        }
      })();
    </script>
  </body>
</html>
